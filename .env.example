# NestJS Backend API Configuration
PORT=3001
NODE_ENV=development

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Database Connection (Prisma PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/music?schema=public"

# Redis Cache & Queue
REDIS_HOST=localhost
REDIS_PORT=6379

# Search Engine (Meilisearch)
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=meilimasterkey

# Security & Tokens
JWT_ACCESS_SECRET=replace_with_a_secure_random_secret
JWT_REFRESH_SECRET=replace_with_a_secure_random_secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# Object Storage (Cloudflare R2 / AWS S3)
STORAGE_ENDPOINT=https://your-r2-endpoint.example.com
STORAGE_ACCESS_KEY_ID=replace_with_storage_access_key
STORAGE_SECRET_ACCESS_KEY=replace_with_storage_secret_key
STORAGE_BUCKET_NAME=music-storage

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=replace_with_cloudinary_api_key
CLOUDINARY_API_SECRET=replace_with_cloudinary_api_secret

# FastAPI AI Service
AI_SERVICE_URL=http://localhost:8000

# Stripe Payments
STRIPE_API_KEY=replace_with_stripe_test_key
STRIPE_WEBHOOK_SECRET=replace_with_stripe_webhook_secret


